
$ Simple cantilever beam — SOL 103 normal modes with point mass
$ Based on sample/simple_beam.bdf (10 m, 5 CBAR elements, 6 nodes + node 7)
$ Steel, solid square cross-section, A = 0.1 m^2 (side = 0.31623 m)
$ Fixed (encastre) at node 1 (x=0), free at node 6 (x=10)
$ CONM2: 100 kg point mass at node 7 (connected to node 6 via RBE3)
$ Units: SI (m, N, kg, Pa)
$
SOL 103
$
SUBCASE 1
  TITLE = Simple Cantilever Beam — Normal Modes with Point Mass
  SPC    = 1
  METHOD = 20
$
BEGIN BULK
$
$ ------------------------------------------------------------------ NODES
$ GRID, GID, CP, X1,   X2, X3, CD, PS, SEID
GRID, 1, , 0.0,  0.0, 0.0
GRID, 2, , 2.0,  0.0, 0.0
GRID, 3, , 4.0,  0.0, 0.0
GRID, 4, , 6.0,  0.0, 0.0
GRID, 5, , 8.0,  0.0, 0.0
GRID, 6, , 10.0, 0.0, 0.0
GRID, 7, , 10.0, 1.0, 0.0
$
$ --------------------------------------------------------------- MATERIAL
$ MAT1, MID, E,      G,        NU,  RHO
$ Steel: E=200 GPa, G=E/(2(1+nu))=76.92 GPa, nu=0.3, rho=7850 kg/m^3
MAT1, 1, 2.0e11, 7.692e10, 0.3, 7850.0
$
$ ------------------------------------------------------------- PROPERTIES
$ PBAR, PID, MID, A,   I1,       I2,       J,        NSM
$ Solid square: a=0.31623 m, I1=I2=a^4/12=8.333e-4, J=0.1406*a^4=1.406e-3
PBAR, 1, 1, 0.1, 8.333e-4, 8.333e-4, 1.406e-3
$ +,   C1,      C2,       D1,       D2,       E1,        E2,       F1,       F2
+,    0.15811, 0.15811, -0.15811, 0.15811, -0.15811, -0.15811, 0.15811, -0.15811
$
$ --------------------------------------------------------------- ELEMENTS
$ CBAR, EID, PID, GA, GB, X1, X2, X3, OFFT
$ Orientation vector (0,1,0): element y = global Y, element z = global Z
CBAR, 1, 1, 1, 2, 0.0, 1.0, 0.0
CBAR, 2, 1, 2, 3, 0.0, 1.0, 0.0
CBAR, 3, 1, 3, 4, 0.0, 1.0, 0.0
CBAR, 4, 1, 4, 5, 0.0, 1.0, 0.0
CBAR, 5, 1, 5, 6, 0.0, 1.0, 0.0
$
PLOTEL, 10, 5, 7
RBE3, 20, , 7, 123456, 1.0, 123456, 6
$
$ ----------------------------------------------------------- CONSTRAINTS
$ SPC1, SID, C,      G1
$ Fix all 6 DOFs at node 1 (encastre)
SPC1, 1, 123456, 1
$
$ --------------------------------------------------------------- POINT MASS
$ CONM2, EID, GID, CID, M
$ 100 kg concentrated mass at node 7 (tip, connected to node 6 via RBE3)
CONM2, 30, 7, 0, 10000.0
$
$ --------------------------------------------------------- EIGENVALUE METHOD
$ EIGRL, SID, V1, V2, ND, MSGLVL, MAXSET, SHFSCL, NORM
$ Extract first 5 modes, MASS normalisation
EIGRL, 20, , , 5, , , , MASS
$
ENDDATA
